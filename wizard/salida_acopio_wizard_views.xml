<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_salida_acopio_wizard_form" model="ir.ui.view">
        <field name="name">salida.acopio.wizard.form</field>
        <field name="model">salida.acopio.wizard</field>
        <field name="arch" type="xml">
            <form string="Salida de Acopio">
                <div class="alert alert-warning" style="margin-bottom: 20px;">
                    <h4><strong>📤 Salida de Acopio del Inventario</strong></h4>
                    <p>
                        Se van a dar de salida residuos desde la ubicación "Acopio" del inventario
                        y se generará automáticamente un manifiesto ambiental donde <strong>SAI es el generador</strong>.
                        Al seleccionar un lote, los datos de clasificación y plan de manejo se precargan automáticamente.
                    </p>
                </div>

                <group string="Información del Transporte" col="2">
                    <field name="transportista_id"
                           placeholder="Transportista (SAI por defecto)..."
                           options="{'no_create': True}"/>
                    <field name="destinatario_id"
                           placeholder="Seleccione el destinatario final..."
                           options="{'no_create': True}"/>
                </group>

                <group string="Resumen" col="2">
                    <field name="total_residuos" readonly="1"/>
                    <field name="cantidad_total" readonly="1"/>
                </group>

                <group string="Residuos a Dar de Salida">
                    <field name="linea_ids" nolabel="1">
                        <list editable="bottom" string="Residuos">
                            <field name="available_product_ids" column_invisible="1"/>
                            <field name="producto_id"
                                   domain="[('id', 'in', available_product_ids)]"
                                   options="{'no_create': True}"/>
                            <field name="available_lot_ids" column_invisible="1"/>
                            <field name="lote_id"
                                   domain="[('id', 'in', available_lot_ids)]"
                                   options="{'no_create': True, 'no_open': True}"/>
                            <field name="nombre_residuo"/>
                            <field name="stock_disponible" readonly="1"/>
                            <field name="cantidad"
                                   decoration-bf="cantidad > stock_disponible"
                                   decoration-danger="cantidad > stock_disponible"/>
                            <field name="clasificaciones_cretib" readonly="1"/>
                            <field name="tipo_manejo_id" optional="show"/>
                            <field name="envase_cantidad" optional="hide"/>
                            <field name="packaging_id" optional="hide"/>
                            <field name="envase_capacidad" optional="hide"/>
                            <field name="residue_type" optional="hide"/>
                        </list>
                        <form string="Detalle del Residuo">
                            <sheet>
                                <group col="2">
                                    <group string="Producto y Lote">
                                        <field name="available_product_ids" invisible="1"/>
                                        <field name="producto_id"
                                               domain="[('id', 'in', available_product_ids)]"
                                               options="{'no_create': True}"/>
                                        <field name="available_lot_ids" invisible="1"/>
                                        <field name="lote_id"
                                               domain="[('id', 'in', available_lot_ids)]"
                                               options="{'no_create': True, 'no_open': True}"/>
                                        <field name="stock_disponible" readonly="1"/>
                                        <field name="cantidad"/>
                                    </group>
                                    <group string="Identificación del Residuo">
                                        <field name="nombre_residuo"/>
                                        <field name="residue_type"/>
                                        <field name="tipo_manejo_id"
                                               options="{'no_create': True}"/>
                                    </group>
                                </group>

                                <group string="Clasificación CRETIB" col="6">
                                    <field name="clasificacion_corrosivo"/>
                                    <field name="clasificacion_reactivo"/>
                                    <field name="clasificacion_explosivo"/>
                                    <field name="clasificacion_toxico"/>
                                    <field name="clasificacion_inflamable"/>
                                    <field name="clasificacion_biologico"/>
                                </group>

                                <group string="Envase" col="4">
                                    <field name="envase_cantidad" string="Unidades"/>
                                    <field name="packaging_id" string="Embalaje"/>
                                    <field name="envase_tipo" string="Tipo (Legacy)"/>
                                    <field name="envase_capacidad"/>
                                </group>

                                <group string="Etiquetado" col="2">
                                    <field name="etiqueta_si"/>
                                    <field name="etiqueta_no"/>
                                </group>
                            </sheet>
                        </form>
                    </field>
                </group>

                <group string="Observaciones">
                    <field name="observaciones"
                           nolabel="1"
                           placeholder="Observaciones adicionales para la salida y el manifiesto..."/>
                </group>

                <div class="alert alert-info" style="margin-top: 15px;">
                    <strong>ℹ️ Validaciones automáticas:</strong>
                    <ul style="margin: 5px 0;">
                        <li>El selector de lotes solo muestra lotes con stock en Acopio</li>
                        <li>No se pueden seleccionar lotes ya entregados o reservados en otras salidas</li>
                        <li>No se puede repetir el mismo lote en dos líneas de la misma salida</li>
                        <li>Al seleccionar un lote, sus datos CRETIB y plan de manejo se precargan automáticamente</li>
                    </ul>
                </div>

                <footer>
                    <button string="✅ Confirmar Salida"
                            name="action_confirmar_salida"
                            type="object"
                            class="btn-primary"
                            confirm="¿Está seguro de que desea realizar la salida de acopio? Se crearán movimientos de inventario y un manifiesto ambiental."/>
                    <button string="Cancelar"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>